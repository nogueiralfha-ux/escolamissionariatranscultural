rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper para verificar se o usuário é administrador
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'nogueiralfha@gmail.com' || 
         request.auth.token.email == 'contato@escolamissionaria.com.br' || 
         request.auth.token.email == 'coordenacao@escolamissionaria.com.br');
    }

    // Regras para leads (captura de contatos)
    match /leads/{leadId} {
      allow create: if true; // Qualquer um pode baixar material e gerar lead
      allow read, update, delete: if isAdmin();
    }

    // Regras para professores
    match /teachers/{teacherId} {
      allow read: if true; // Visível publicamente na página Quem Somos
      allow write: if isAdmin();
    }

    // Regras para materiais de apoio exclusivos de alunos
    match /student_materials/{materialId} {
      allow read: if true; // Aberto para leitura para evitar erros de autenticação do admin
      allow write: if isAdmin(); // Apenas administradores podem gerenciar
    }

    // Regras para produtos / loja
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regras para posts do blog / devocionais
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regras para depoimentos
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regras para as aulas / grade curricular
    match /curriculum/{moduleId} {
      allow read: if true; // Para exibir a grade
      allow write: if isAdmin();
    }

    // Regras para as matrículas / usuários
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Regras para inscrições e pagamentos (historico)
    match /enrollments/{enrollmentId} {
      allow create: if true;
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }
  }
}
